# Copy to .env on the server and fill in.  cp .env.server.example .env

# The server's own IP (reachable by clients on the LAN). Used for the HTTPS URL
# and for media ICE candidates.
SERVER_IP=10.130.9.241

# LiveKit credentials — generate strong values (do NOT use the local devkey).
# Secret must be at least 32 characters.  Generate one with:  openssl rand -hex 24
LIVEKIT_API_KEY=APIvoiceagent
LIVEKIT_API_SECRET=replace-with-a-random-secret-at-least-32-chars

# Sarvam AI key — https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# Host ports. Change ONLY if these clash with your other apps.
# HTTPS_PORT is what you open in the browser: https://SERVER_IP:HTTPS_PORT
# If you change LK_UDP_PORT, also change rtc.udp_port in livekit.server.yaml to match.
HTTPS_PORT=8443
LK_TCP_PORT=7881
LK_UDP_PORT=7882
