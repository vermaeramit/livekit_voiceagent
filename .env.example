# --- Option A: LiveKit Cloud — from https://cloud.livekit.io (Settings → Keys)
# Use these when running the agent directly (python agent.py ...).
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Option B: Self-hosted via docker-compose
# The LIVEKIT_* vars above are IGNORED in compose — they're set in docker-compose.yml
# to match livekit.yaml. Only SARVAM_API_KEY below is read from this file by compose.

# Sarvam AI — from https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx
