# HTTPS for a LAN server with no domain — Caddy serves a self-signed cert for the
# server IP (its own internal CA). Browsers show a one-time "Not secure → Proceed"
# warning; after that the page is a secure context, so the microphone works.
{
	auto_https disable_redirects
	# Clients connecting to an IP send no SNI, so Caddy can't match a cert and the
	# TLS handshake fails ("internal error"). This makes the IP's cert the default
	# for SNI-less connections.
	default_sni {$SERVER_IP}
}

# NOTE: the https:// scheme is required — without it Caddy serves plain HTTP on a
# non-443 port, which causes ERR_SSL_PROTOCOL_ERROR in the browser.
https://{$SERVER_IP}:{$HTTPS_PORT} {
	bind 0.0.0.0
	tls internal              # self-signed cert from Caddy's internal CA (no domain needed)

	# LiveKit signaling — HTTP validate + WebSocket upgrade — must be wss:// since
	# the page is https://. Proxy to the internal LiveKit server.
	@livekit path /rtc /rtc/*
	reverse_proxy @livekit livekit:7880

	# Everything else (web client + /token) → the token server.
	reverse_proxy token:3000
}
